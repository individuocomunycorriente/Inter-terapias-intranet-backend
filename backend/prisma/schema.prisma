// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Administrator {
  id        Int      @id @default(autoincrement())
  email     String   @unique // Ej: admin@interterapia.cl
  password  String   // Contraseña encriptada (con bcrypt)
  name      String   // Nombre del administrador
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 1. Modelo para los Profesionales (Intranet y Sección de difusión)
model Professional {
  id           Int              @id @default(autoincrement())
  name         String           // Nombre completo del profesional
  email        String           @unique // Debe ser único y terminar en @interterapia.cl
  password     String           // Contraseña encriptada (con bcrypt)
  specialty    String           // Especialidad (Kinesiólogo, Fonoaudiólogo, etc.)
  imageUrl     String?          // Foto para la sección "Profesionales" del sitio web
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  
  // Relación: Un profesional escribe muchos reportes clínicos
  clinicalReports ClinicalReport[]
}

// 2. Modelo para los Pacientes / Clientes
model Patient {
  id           Int              @id @default(autoincrement())
  fullName     String           // Nombre completo del paciente
  rut          String           @unique // Identificador único chileno (opcional/recomendado)
  age          Int
  contactPhone String?
  guardianName String?          // Nombre del apoderado o tutor (muy común en terapias)
  initialSurveyData Json?       // Aquí guardamos los datos importados de la encuesta inicial (Google Forms)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  // Relación: Un paciente tiene un historial de muchos reportes clínicos
  clinicalReports ClinicalReport[]
}

// 3. Modelo para las Evoluciones Clínicas (Ficha Clínica)
model ClinicalReport {
  id                  Int          @id @default(autoincrement())
  
  // Relaciones obligatorias
  patientId           Int
  patient             Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  professionalId      Int
  professional        Professional @relation(fields: [professionalId], references: [id])
  
  // Campos del reporte clínico según requerimientos del documento
  date                DateTime     @default(now()) // Fecha de la sesión
  therapeuticGoal     String       // Objetivos terapéuticos a trabajar
  activityPerformed   String       // Actividad realizada en sesión
  goalsAchieved       String       // Cumplimiento de logros / Objetivos alcanzados
  clinicalObservations String      // Observaciones clínicas del profesional
  behaviorObservation String       // Observación de trato / Conducta
  additionalComments  String?      // Observaciones adicionales o tareas para la casa

  createdAt           DateTime     @default(now())
}
